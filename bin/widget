#!/usr/bin/env bash
# Render the DATA-FILLED Journal widget fragment from a civic node's own identity.
#
# Counterpart to widget/public.html — which is the baked BASELINE (a static shell with
# a DORMANT postMessage API and NO data, refreshed only by bumping this submodule's
# pin). This build is meant to run from the WORKSPACE root, where a civic node carries
# its identity as files, and emit the SAME anecdote-widget fragment — same classes,
# same `anecdote:widget:` postMessage contract, so a host can't tell which build it
# received — but populated with THIS node's own FIRST-PARTY journal locator.
#
#   bin/widget --url ORIGIN [--mount journal] \
#              [--out -|PATH] [--updated YYYY-MM-DD]
#
# The QR is a FIRST-PARTY DIRECT locator — no hub, no geo-fill. Contrast tell/bin/widget,
# which bakes a STATELESS hub locator: a tell is cross-jurisdictional, so its QR hands a
# geo-less stem to a shared hub that fills the scanner's state and redirects. A journal is
# the opposite posture: this node's OWN public record, self-hosted on its OWN domain under
# the `journal` mount (CONSTITUTION/AGENTS: "first-party claims beat hearsay"). So the QR
# points straight at
#       <origin>/<mount>/
# the node's own site — no indirection, resolves the same everywhere. qrencode bakes the QR
# as inline SVG (no runtime JS, no external request); absent qrencode the fragment degrades
# to a plain text link so a node build never breaks on a missing tool.
set -euo pipefail

url=""; mount="journal"; out="-"; updated=""
while [ $# -gt 0 ]; do
  case "$1" in
    --url) url="$2"; shift 2;;
    --mount) mount="$2"; shift 2;;
    --out) out="$2"; shift 2;;
    --updated) updated="$2"; shift 2;;
    *) echo "bin/widget: unknown arg: $1" >&2; exit 1;;
  esac
done
[ -n "$url" ] || {
  echo "usage: bin/widget --url ORIGIN [--mount journal] [--out PATH] [--updated DATE]" >&2
  exit 1
}

# The origin must be an http(s) URL — it is baked into an href and encoded into a QR, so
# constrain it to a scheme we can serve and a single token (no spaces/quotes that could
# break out of the attribute).
printf '%s' "$url" | grep -Eq '^https?://[^[:space:]"<>]+$' \
  || { echo "bin/widget: --url must be an http(s) URL (got: $url)" >&2; exit 1; }
# The mount becomes a URL path segment; keep it a plain slug so it can only ever form a
# path piece, never inject extra path/query (mirrors tell/bin/widget's label guard).
printf '%s' "$mount" | grep -Eq '^[A-Za-z0-9]([A-Za-z0-9_-]*[A-Za-z0-9])?$' \
  || { echo "bin/widget: --mount must be a path slug [A-Za-z0-9_-] (got: $mount)" >&2; exit 1; }

: "${updated:=$(date -u +%Y-%m-%d)}"

origin="${url%/}"
locator="${origin}/${mount}/"
host="${origin#*://}"                 # scheme-less, for the data-node stamp + caption
node="${host%/}/${mount}/"
locator_attr="${locator//&/&amp;}"    # &-escape for an HTML attribute

# Bake the QR as inline SVG: drop the XML prolog, the generator comment, and the fixed
# cm sizing (the panel sizes it via CSS). Degrade to a text link without qrencode.
qr_block() {
  if command -v qrencode >/dev/null 2>&1; then
    printf '<figure class="anecdote-widget__qr" role="img" aria-label="QR code linking to this node'"'"'s Journal">\n'
    qrencode -t SVG -m 1 -o - "$locator" \
      | sed -e '/<?xml/d' -e '/<!-- Created with qrencode/d' -e 's/ width="[0-9.]*cm" height="[0-9.]*cm"//'
    printf '<figcaption><a href="%s">%s</a></figcaption>\n' "$locator_attr" "$node"
    printf '</figure>\n'
  else
    printf '<p class="anecdote-widget__note">QR omitted (qrencode unavailable at build). Open <a href="%s">%s</a>.</p>\n' "$locator_attr" "$node"
  fi
}

render() {
cat <<HTML
<!-- anecdote.channel widget — DATA-FILLED build for "journal", rendered from a civic node's
     own identity by journal/bin/widget run from the workspace root. Counterpart to the baked
     BASELINE in widget/public.html: same fragment contract (classes + anecdote:widget:
     postMessage API), but populated with this node's own first-party journal locator QR.
     Regenerated by the node's build — do not hand-edit; change journal/bin/widget instead. -->
<section class="anecdote-widget" data-widget="journal" data-updated="${updated}" data-node="${node}">
  <header class="anecdote-widget__head">
    <h2 class="anecdote-widget__title">Journal</h2>
    <span class="anecdote-widget__tag">record</span>
  </header>
  <div class="anecdote-widget__body">
    <p class="anecdote-widget__lede">Scan to read this node's public record.</p>
$(qr_block | sed 's/^/    /')
    <p class="anecdote-widget__note">
      A first-party locator — it points straight at this node's own journal on
      <code>${host}</code>, no hub and no redirect. It is the node's published record:
      the polls it ran and the outcomes it stands behind.
    </p>
  </div>

  <style>
    .anecdote-widget {
      display: flex;
      flex-direction: column;
      gap: .5rem;
      height: 100%;
      box-sizing: border-box;
      padding: 1rem 1.1rem;
      border: 1px solid #d9d9e0;
      border-radius: 10px;
      background: #fff;
      color: #1d1d22;
      font: 15px/1.5 system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    }
    .anecdote-widget__head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: .5rem;
      border-bottom: 1px solid #ececf1;
      padding-bottom: .4rem;
    }
    .anecdote-widget__title { margin: 0; font-size: 1.15rem; font-weight: 650; }
    .anecdote-widget__tag {
      font-size: .72rem;
      letter-spacing: .04em;
      text-transform: uppercase;
      color: #6b6b78;
    }
    .anecdote-widget__body { margin: 0; }
    .anecdote-widget__lede { margin: 0 0 .5rem; }
    .anecdote-widget__qr { margin: 0 0 .5rem; text-align: center; }
    .anecdote-widget__qr svg { width: 168px; height: 168px; image-rendering: pixelated; }
    .anecdote-widget__qr figcaption { margin-top: .3rem; font-size: .8rem; word-break: break-all; }
    .anecdote-widget__qr a { color: inherit; }
    .anecdote-widget__note { margin: 0; font-size: .82rem; color: #6b6b78; }
  </style>

  <script>
  (function () {
    "use strict";
    var NAME = "journal";
    var FLAG = "__anecdoteWidget_" + NAME;
    if (window[FLAG]) return;          // guard double-init when panels share one document
    window[FLAG] = true;

    var PROTO = "anecdote:widget:";
    function post(target, msg) { try { target.postMessage(msg, "*"); } catch (e) {} }

    // Announce readiness exactly once. No timer, no polling — the widget is otherwise inert.
    var ready = { type: PROTO + "ready", widget: NAME };
    if (window.parent && window.parent !== window) post(window.parent, ready);
    post(window, ready);

    // Dormant: only RESPOND to host-initiated messages addressed to this widget. The widget
    // never changes behaviour on its own; the host opts in by sending a message.
    window.addEventListener("message", function (ev) {
      var data = ev && ev.data;
      if (!data || typeof data !== "object") return;
      if (data.widget && data.widget !== NAME) return;     // not addressed to us
      if (data.type === PROTO + "ping") {
        var reply = { type: PROTO + "pong", widget: NAME };
        if (ev.source) post(ev.source, reply); else post(window, reply);
      }
    });
  })();
  </script>
</section>
HTML
}

if [ "$out" = "-" ]; then
  render
else
  mkdir -p "$(dirname "$out")"
  render > "$out"
  echo "bin/widget: wrote $out ($node)" >&2
fi
